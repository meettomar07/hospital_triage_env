# OpenAI-compatible LLM endpoint (required for model-driven inference)
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier (required)
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Environment server URL (defaults to local FastAPI app)
ENV_BASE_URL=http://127.0.0.1:7860

# Authentication token (preferred)
HF_TOKEN=your_token_here

# Optional fallback key if your endpoint expects API_KEY
API_KEY=

# Optional debug switch for local diagnostics
DEBUG_LOGS=0
